DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Public site origin. Used for canonical URLs, OG images, sitemap, robots.
# No trailing slash. Example: https://wcpredictionleague.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# football-data.org API token (https://www.football-data.org/client/register)
# Used by the admin "Sync from API" buttons. Server-only — never expose to the browser.
FOOTBALL_DATA_TOKEN=your_token_here
