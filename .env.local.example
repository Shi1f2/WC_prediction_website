DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Public site origin. Used for canonical URLs, OG images, sitemap, robots.
# No trailing slash. Example: https://wcpredictionleague.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# thesportsdb.com is the live-data provider. The public test key "3" works
# without signup and is the default — leave SPORTSDB_KEY blank for that.
# If you support thesportsdb on Patreon ($9/mo) for a dedicated key with
# higher rate limits and live in-play minute data, set it here.
# SPORTSDB_KEY=your_patreon_key_here

# Optional. Defaults to FIFA World Cup 2026 on thesportsdb. Override if their IDs change.
# SPORTSDB_LEAGUE_ID=4429
# SPORTSDB_SEASON=2026
